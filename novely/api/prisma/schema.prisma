// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


enum SubscriptionCycle {
  WEEKLY
  BIWEEKLY
  MONTHLY
  BIMONTHLY
  QUARTERLY
  SEMIANNUALLY
  YEARLY
}

enum BillingType {
  BOLETO
  CREDIT_CARD
  PIX
  UNDEFINED
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  OVERDUE
  EXPIRED
  CANCELLED
}

enum LedgerType {
  PAYMENT
  COMMISSION
  SPLIT
  REFUND
  CASHOUT
}

enum LedgerDirection {
  CREDIT
  DEBIT
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  RELEASED
  CANCELED
}


enum CashoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
}


model Saas {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  apiKeyHash  String   @unique
  asaasId     String   @unique
  comissao    Decimal  @default(0.00)
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sellers     Seller[]
  ledger      LedgerEntry[]
  reservations Reservation[]
  cashouts    Cashout[]   // 🔥 ADD

  @@map("saas")
}

model Seller {
  id              String   @id @default(cuid())
  name            String
  email           String   @unique
  cpfCnpj         String   @unique
  mobilePhone     String

  asaasCustomerId String?  @unique

  asaasWalletId   String?  @unique
  asaasApiKey     String?  @db.Text

  saasId          String
  saas            Saas     @relation(fields: [saasId], references: [id])

  subscriptions   Subscription[]
  ledger          LedgerEntry[]
  reservations    Reservation[]
  cashouts        Cashout[]   // 🔥 ADD

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("sellers")
}


model Subscription {
  id              String             @id @default(cuid())
  asaasId         String             @unique

  value           Decimal            @db.Decimal(10, 2)
  cycle           SubscriptionCycle
  billingType     BillingType
  status          SubscriptionStatus @default(PENDING)

  description     String?            @db.Text

  nextDueDate     DateTime
  endDate         DateTime?

  maxPayments     Int?
  externalRef     String?

  checkoutUrl     String?            @db.Text

  sellerId        String
  seller          Seller             @relation(fields: [sellerId], references: [id])

  payments        Payment[]
  ledger          LedgerEntry[]
  reservations    Reservation[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("subscriptions")
}


model Payment {
  id              String   @id @default(cuid())

  asaasPaymentId  String   @unique

  value           Decimal  @db.Decimal(10,2)
  netValue        Decimal? @db.Decimal(10,2)

  billingType     BillingType
  status          String

  dueDate         DateTime
  paidAt          DateTime?

  invoiceUrl      String?  @db.Text

  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id])

  ledger          LedgerEntry[]
  reservation     Reservation?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("payments")
}

model WebhookEvent {
  id          String   @id @default(cuid())

  event       String
  asaasId     String?

  payload     Json

  processed   Boolean  @default(false)

  createdAt   DateTime @default(now())

  @@map("webhook_events")
}


model LedgerEntry {
  id              String   @id @default(cuid())

  saasId          String?
  sellerId        String?
  subscriptionId  String?
  paymentId       String?

  type            LedgerType
  direction       LedgerDirection

  amount          Decimal  @db.Decimal(10,2)

  description     String?

  createdAt       DateTime @default(now())

  saas            Saas?         @relation(fields: [saasId], references: [id])
  seller          Seller?       @relation(fields: [sellerId], references: [id])
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])
  payment         Payment?      @relation(fields: [paymentId], references: [id])

  @@index([saasId])
  @@index([sellerId])
  @@index([paymentId])
  @@index([subscriptionId])

  @@map("ledger_entries")
}


model Reservation {
  id String @id @default(cuid())

  saasId String
  sellerId String
  subscriptionId String?
  paymentId String @unique

  grossAmount Decimal @db.Decimal(10,2)

  platformFee Decimal @db.Decimal(10,2)
  saasAmount Decimal @db.Decimal(10,2)

  isConsumed Boolean @default(false)
consumedAt DateTime?

  status ReservationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  saas Saas @relation(fields: [saasId], references: [id])
  seller Seller @relation(fields: [sellerId], references: [id])
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
  payment Payment @relation(fields: [paymentId], references: [id])

  @@index([saasId])
  @@index([sellerId])
  @@index([paymentId])
  @@index([subscriptionId])
}


model Cashout {
  id String @id @default(cuid())

  saasId String
  sellerId String

  amount Decimal @db.Decimal(10,2)
  status CashoutStatus @default(PENDING)

  externalId String?
  errorMessage String? @db.Text

  processedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  saas Saas @relation(fields: [saasId], references: [id])
  seller Seller @relation(fields: [sellerId], references: [id])

  @@index([saasId])
  @@index([sellerId, status])
}

model CashoutLock {
  sellerId String @id
  lockedAt DateTime
}